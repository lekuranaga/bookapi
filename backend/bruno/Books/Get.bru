meta {
  name: Get
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/{{apiVersion}}/books/{{bookId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

vars:pre-request {
  bookId: 22222222-2222-2222-2222-222222222221
}

tests {
  test("status 200", function () {
    expect(res.status).to.equal(200);
  });
}
